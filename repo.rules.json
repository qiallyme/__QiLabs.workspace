{
  "ignore_globs": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.astro/**",
    "**/.turbo/**",
    "**/target/**",
    "**/.git/**",
    "**/.next/**",
    "**/.output/**",
    "**/coverage/**",
    "**/logs/**",
    "**/.trash/**",
    "**/__pycache__/**",
    "**/venv/**",
    "**/.venv/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.DS_Store",
    "**/Thumbs.db",
    "apps/**/node_modules/**",
    "sites/**/node_modules/**",
    "rag_env/**",
    ".husky/**",
    ".vscode/**",
    ".idea/**",
    "README.md",
    "package.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "LICENSE",
    "TODO.md"
  ],
  "filename": {
    "no_spaces": true,
    "allowed_chars_regex": "^[a-z0-9_.-]+$",
    "max_base_len": 50,
    "prefer_underscore": true,
    "capitalization": "lowercase"
  },
  "foldername": {
    "no_spaces": true,
    "capitalization": "lowercase",
    "allowed_regex": "^[a-z0-9][a-z0-9_-]*$"
  },
  "scripts": {
    "folder": "scripts/",
    "script_folders": [
      "ai",
      "automate",
      "config",
      "core",
      "deploy",
      "index",
      "ingest",
      "process",
      "services",
      "tests",
      "tools"
    ],
    "archive_folders": [
      "_archive"
    ],
    "allowed_extensions": [
      ".py",
      ".ps1",
      ".ts",
      ".js",
      ".mjs",
      ".json",
      ".yaml",
      ".yml",
      ".md",
      ".bat",
      ".ahk",
      ".xml"
    ],
    "prefix_naming": {
      "enabled": true,
      "separator": "_",
      "pattern_regex": "^[a-z0-9]+_[a-z0-9_]+$",
      "exceptions": [
        "__init__.py",
        "README.md",
        "USAGE.md"
      ]
    },
    "reserved_prefixes": [
      "agent",
      "ai",
      "audio",
      "auth",
      "calendar",
      "clean",
      "convert",
      "core",
      "crm",
      "debug",
      "deploy",
      "dir",
      "file",
      "frontmatter",
      "health",
      "index",
      "inbox",
      "job",
      "log",
      "mail",
      "map",
      "memory",
      "norm",
      "pdf",
      "prompt",
      "rag",
      "reg",
      "run",
      "sched",
      "search",
      "sms",
      "sync",
      "test",
      "valid",
      "vault",
      "video",
      "web",
      "worker"
    ]
  }
}